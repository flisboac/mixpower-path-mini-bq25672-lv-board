			(plotpadnumbers no)
			(hidednponfab no)
			(sketchdnponfab yes)
			(crossoutdnponfab yes)
			(subtractmaskfromsilk no)
			(outputformat 4)
			(mirror no)
			(drillshape 0)
			(scaleselection 1)
			(outputdirectory "plot/pcb/")

	(text "* Ship FET, see\n  Battery Charger's\n  datasheet."
		(exclude_from_sim no)
		(at 129.286 71.374 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "73541b7f-fbfc-45e4-8471-bcc675239526")
	)
	(text "* Vbat,\n  min = 2.5V\n  max = ~4.8V\n* Ibat,\n  max = 3A"
		(exclude_from_sim no)
		(at 41.91 62.23 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "a5351e23-baf0-4ac3-8c9f-bb73acadd35e")
	)
	(text "[input-battery] Battery Input: Connectors, Protections and Fuel Gauge"
		(exclude_from_sim no)
		(at 113.03 20.32 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.4064)
				(bold yes)
				(color 72 72 72 1)
			)
		)
		(uuid "a900feed-6cf7-4ba2-a231-52efe9eb385d")
	)
	(text "* Battery protection IC. Because BC and FG don't offer it.\n  Also, most LiPo batteries comes with the DW01A, which may be\n  insufficient (especially for overdischarge)."
		(exclude_from_sim no)
		(at 83.82 99.06 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "bf690539-54f5-4f61-b264-1e3cac09960f")
	)
	(text "* Reverse polarity protection.\n  The battery protection IC\n  doesn't explicitly offer it. "
		(exclude_from_sim no)
		(at 63.5 99.06 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "c4a07b08-c33d-4954-a666-556d18589bf8")
	)
	(text "* Select VBAT to\n  prevent MCU\n  from working on\n  ship-mode,\n  BATP otherwise."
		(exclude_from_sim no)
		(at 179.6474 28.1762 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "c62362d3-d379-40c2-8167-2da2329b6fd9")
	)
	(text "* Snubber RC,\n  place near the\n  connector"
		(exclude_from_sim no)
		(at 60.96 63.5 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "e250abe6-9be4-4dad-abe3-7da0423b5eb8")
	)
	(text "* Battery soft-disconnect resistor. If un-populated, it does not\n  disconnect the battery per se, it just prevents the battery charger\n  from sensing the battery's presence and voltage, and therefore\n  prevents it from driving SDRV.\n* The board will still work with external/USB power, but won't charge.\n  Hopefully, if un-populated, it will remove any battery-powered\n  quiescent power consumption from the system, which could work as\n  an even lower-powered form of ship mode, once said mode is\n  activated. A new revision of this board will replace this resistor\n  with a switch if this idea works.\n"
		(exclude_from_sim no)
		(at 135.382 40.132 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "e503f29b-bce6-4ad8-bf81-ae537abf2207")
	)

	)
	(text "* Constant current sink, required for any USB-C Source role.\n* Activated by asserting DRAIN (active high).\n* Can be non-populated if not using board as a USB-PD Source.\n* Sink current ~75mA, regardless of voltage. ~300uA max quiescent ONLY when sinking.\n* Time to discharge to 1V, 100uF VBUS capacitance: 20V = ~80ms; 5V = ~11ms"
		(exclude_from_sim no)
		(at 114.046 28.194 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
			)
			(justify left)
		)
		(uuid "f31c1552-92a4-4282-8ed3-ee1480c56071")
	)

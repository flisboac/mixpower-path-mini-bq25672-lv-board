	(text "* Fast-role Swap MOSFETS, as required by this\n  functionality (and as per datasheets/app notes).\n"
		(exclude_from_sim no)
		(at 59.69 193.04 0)
		(effects
			(font
				(size 0.762 0.762)
				(color 72 72 72 1)
